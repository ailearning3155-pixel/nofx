# ============================================================
# APEX Trading OS — Environment Configuration
# Copy this to .env and fill in your values
# ============================================================

# ============================================================
# TRADING MODE — THE MASTER SWITCH
# Stage 1: backtest   (safe, historical data, NO real orders placed)
# Stage 2: paper      (live prices, OANDA practice account, fake money)
# Stage 3: live       (real money — only after stages 1+2 succeed!)
# ============================================================
TRADING_MODE=backtest

# --- App Settings ---
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
SECRET_KEY=change_this_to_a_random_secret_key_minimum_32_characters
DEBUG=true

# --- OANDA ---
# Get from: oanda.com → My Account → Manage API Access
OANDA_ACCOUNT_ID=101-001-XXXXXXXX-001
OANDA_API_KEY=your_oanda_api_key_here
OANDA_ENVIRONMENT=practice          # practice = paper trading | live = real money

# --- Database ---
DATABASE_URL=postgresql://apex:apex_password@localhost:5432/apex_db
REDIS_URL=redis://localhost:6379/0

# --- AI Model API Keys (add the ones you have, leave others blank) ---
# Recommended starting order: DeepSeek first (cheapest)
DEEPSEEK_API_KEY=sk-...            # https://platform.deepseek.com
OPENAI_API_KEY=sk-...              # https://platform.openai.com
ANTHROPIC_API_KEY=sk-ant-...       # https://console.anthropic.com
GOOGLE_API_KEY=AIza...             # https://aistudio.google.com
GROK_API_KEY=xai-...               # https://console.x.ai
QWEN_API_KEY=sk-...                # https://dashscope.aliyuncs.com

# --- AI Settings ---
AI_REQUEST_TIMEOUT=30
AI_MAX_RETRIES=3
AI_TEMPERATURE=0.3
DEFAULT_AI_MODEL=deepseek

# --- Trading Settings ---
DEFAULT_INSTRUMENTS=EUR_USD,GBP_USD,USD_JPY,XAU_USD,US500
CANDLE_GRANULARITY=H1
MAX_OPEN_TRADES=3
DEFAULT_RISK_PER_TRADE=1.0          # % of account per trade (keep at 1% to start)
MAX_DAILY_LOSS_PCT=3.0              # kill switch triggers at this daily loss %
MAX_DRAWDOWN_PCT=10.0               # overall drawdown kill switch

# --- AI Competition Mode ---
COMPETITION_MODE=true
COMPETITION_STARTING_BALANCE=100000
COMPETITION_RESET_INTERVAL=monthly

# --- Debate Engine ---
DEBATE_ENABLED=true
DEBATE_TIMEOUT=45
MIN_CONSENSUS_REQUIRED=3

# --- News Sentiment (optional) ---
# Free plan: https://newsapi.org
NEWS_API_KEY=
NEWS_UPDATE_INTERVAL=900
SENTIMENT_MODEL=finbert

# --- Economic Calendar ---
CALENDAR_PROVIDER=forexfactory
CALENDAR_LOOKAHEAD_HOURS=24
HIGH_IMPACT_PAUSE=true

# --- Telegram Bot (optional but recommended for live trading) ---
# Create bot: Telegram → @BotFather → /newbot
# Get your chat ID: message @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ALERTS_ENABLED=false
TELEGRAM_ALERT_ON_TRADE=true
TELEGRAM_ALERT_ON_DEBATE=false
TELEGRAM_DAILY_REPORT=true
TELEGRAM_DAILY_REPORT_TIME=20:00

# --- Frontend ---
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000
VITE_APP_NAME=APEX Trading OS
