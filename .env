# ============================================================
# APEX Trading OS — Configuration
# Fill in your API keys below, then restart the server
# ============================================================

TRADING_MODE=backtest

# ── App ──
APP_ENV=development
DEBUG=true
SECRET_KEY=change_this_before_going_live

# ── OANDA (get from: oanda.com → Manage API Access) ──
OANDA_ACCOUNT_ID=
OANDA_API_KEY=
OANDA_ENVIRONMENT=practice

# ── Database (docker-compose provides these) ──
DATABASE_URL=postgresql://apex:apex_password@localhost:5432/apex_db
REDIS_URL=redis://localhost:6379/0

# ── AI Models (add at least one) ──
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GROK_API_KEY=
QWEN_API_KEY=

# ── AI Settings ──
DEFAULT_AI_MODEL=deepseek
AI_TEMPERATURE=0.3
AI_REQUEST_TIMEOUT=30
AI_MAX_RETRIES=3

# ── Trading ──
DEFAULT_INSTRUMENTS=EUR_USD,GBP_USD,USD_JPY,XAU_USD,US500
CANDLE_GRANULARITY=H1
MAX_OPEN_TRADES=3
DEFAULT_RISK_PER_TRADE=1.0
MAX_DAILY_LOSS_PCT=3.0
MAX_DRAWDOWN_PCT=10.0

# ── Features ──
COMPETITION_MODE=true
DEBATE_ENABLED=true
TELEGRAM_ALERTS_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
NEWS_API_KEY=
